# slots_docker_build.gbnf — constrain slot-filling output for docker_build intent
root ::= slot-path optional-slots
optional-slots ::= ( "\n" optional-slot )*

slot-path ::= "path=" path-value

optional-slot ::= slot-tag | slot-file

slot-tag  ::= "tag=" image-tag
slot-file ::= "file=" path-value

image-tag  ::= [a-zA-Z0-9] [a-zA-Z0-9_./:@-]*
path-value ::= "/" [a-zA-Z0-9_./-]* | "."
