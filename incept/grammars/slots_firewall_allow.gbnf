# slots_firewall_allow.gbnf — constrain slot-filling output for firewall_allow intent
root ::= slot-port optional-slots
optional-slots ::= ( "\n" optional-slot )*

slot-port ::= "port=" number

optional-slot ::= slot-protocol

slot-protocol ::= "protocol=" protocol-value

protocol-value ::= "tcp" | "udp"
number         ::= [0-9]+
